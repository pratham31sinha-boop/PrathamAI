{
  "rewrites": [
    { "source": "/api/app", "destination": "/api/app.py" },
    { "source": "/api/app/(.*)", "destination": "/api/app.py" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}
